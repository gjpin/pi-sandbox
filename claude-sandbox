#!/usr/bin/env bash

set -uo pipefail

function usage() {
    cat >&2 <<EOF
Usage: $0 [--target-dir <dir>] [--use-profile <file>] [--write-profile <file>] [--write-base-profile <file>] [--no-workaround] [--] <program> <arguments>

Options:
  --target-dir <dir>            Directory to generate claude workaround rules "(allow file-read* literal(..))" for. (default: .)
  --use-profile <file>          Use specified file as base profile template instead of the built-in noread.sb.
  --write-profile <file>        Write the generated sandbox profile to specified file and exit.
  --write-base-profile <file>   Write the built-in noread.sb profile to specified file and exit.
  --no-workaround               Don't generate workaround rules, maybe use this when claude-code is fixed!
  -h, --help                    Show this help message

Example:
  $0 --target-dir /path/to/dir -- claude
  $0 --use-profile custom.sb -- claude
  $0 --write-profile profile.sb
EOF
    exit 1
}


function escape_for_sandbox() {
    local path="$1"
    # Escape backslashes first, then double quotes
    path="${path//\\/\\\\}"
    path="${path//\"/\\\"}"
    echo "$path"
}

function generate_workaround_allow_read_rules() {
    local tgt_dir="$1"

    # Ensure path starts with /
    if [[ ! "${tgt_dir}" =~ ^/ ]]; then
        echo "path ${tgt_dir} didn't start with /"
        exit 1
    fi

    local components=()
    IFS='/' read -ra components <<< "${tgt_dir}"

    local current_path=""
    local all_rules=""

    for component in "${components[@]}"; do
        if [[ -z "${component}" ]]; then
            # Handle leading / or consecutive //
            if [[ -z "${current_path}" ]]; then
                current_path="/"
            fi
            continue
        fi

        if [[ "${current_path}" == "/" ]]; then
            current_path="/$component"
        else
            current_path="$current_path/$component"
        fi

        # Escape the path for sandbox profile
        local escaped_path
        escaped_path="$(escape_for_sandbox "${current_path}")"

        # Use `literal` to allow only *listing* directory contents:
        # Reading files in directory is still forbidden
        all_rules+="(allow file-read* (literal \"${escaped_path}\"))"$'\n'
    done

    echo "${all_rules}"
}

# Array to accumulate positional arguments
POSITIONAL_ARGS=()

while [[ $# -gt 0 ]]; do
    case "$1" in
        --target-dir)
            TARGET_DIR="$2"
            shift 2
            ;;
        --use-profile)
            USE_PROFILE="$2"
            shift 2
            ;;
        --write-profile)
            WRITE_PROFILE="$2"
            shift 2
            ;;
        --write-base-profile)
            WRITE_BASE_PROFILE="$2"
            shift 2
            ;;
        --no-workaround)
            NO_WORKAROUND=1
            shift 1
            ;;
        -h|--help)
            usage
            ;;
        --)
            # Stop parsing options, collect remaining args
            shift
            break
            ;;
        -*)
            echo "Error: Unknown option: $1" >&2
            echo "" >&2
            usage
            ;;
        *)
            # Non-option argument, stop parsing options
            break
            ;;
    esac
done

# Collect all remaining arguments as positional arguments
while [[ $# -gt 0 ]]; do
    POSITIONAL_ARGS+=("$1")
    shift
done

# Default to bash if no command provided
if [[ ${#POSITIONAL_ARGS[@]} -eq 0 ]]; then
    POSITIONAL_ARGS=("bash")
fi

# Detect if already running inside a sandbox (nested sandboxing is not supported on macOS)
if sandbox-exec -p '(version 1)(allow default)' true 2>/dev/null; [ $? -eq 71 ]; then
    echo "Error: Already running inside a sandbox. Nested sandboxing is not supported on macOS." >&2
    echo "If you're running inside claude-sandbox, you cannot nest another sandbox." >&2
    exit 1
fi

# If --write-base-profile is set, dump the built-in profile and exit
if [[ -n "${WRITE_BASE_PROFILE:-}" ]]; then
    echo "${NOREAD_SB_CONTENT}" > "${WRITE_BASE_PROFILE}"
    exit 0
fi

TARGET_DIR="${TARGET_DIR:-$(pwd)}"
# realpath -m requires GNU coreutils; macOS BSD realpath doesn't support -m
TARGET_DIR="$(realpath -m "${TARGET_DIR}" 2>/dev/null || realpath "${TARGET_DIR}" 2>/dev/null || echo "${TARGET_DIR}")"
NO_WORKAROUND="${NO_WORKAROUND:-0}"

# Determine the base profile content
if [[ -n "${USE_PROFILE:-}" ]]; then
    if [[ ! -f "${USE_PROFILE}" ]]; then
        echo "Error: Profile file not found: ${USE_PROFILE}" >&2
        exit 1
    fi
    BASE_PROFILE_CONTENT="$(cat "${USE_PROFILE}")"
else
    BASE_PROFILE_CONTENT="${NOREAD_SB_CONTENT}"
fi

# Build the full profile
if [[ "${NO_WORKAROUND}" == 0 ]]; then
    WORKAROUND_RULES="$(generate_workaround_allow_read_rules "${TARGET_DIR}")"

    FULL_PROFILE="$(cat <<PROFILE_EOF
${BASE_PROFILE_CONTENT}

;; Generated allow-read rules for: ${TARGET_DIR}
;; for some reason claude-code needs list access to all parent directories of TARGET_DIR
;; - it doesn't need access to read the contents of directories, only the directories
;; themselves. Otherwise it will set PATH to "" and disable colored output
${WORKAROUND_RULES}
PROFILE_EOF
)"
else
    FULL_PROFILE="${BASE_PROFILE_CONTENT}"
fi

# If --write-profile is set, write and exit
if [[ -n "${WRITE_PROFILE:-}" ]]; then
    echo "${FULL_PROFILE}" > "${WRITE_PROFILE}"
    exit 0
fi

# Write to a temp file for sandbox-exec
PROFILE_FILE="$( (mkdir -p "${HOME}/.config/claude-sandbox" && mktemp "${HOME}/.config/claude-sandbox/profile.sb.XXXXXXXXXX") 2>/dev/null || mktemp "/tmp/claude-sandbox-profile.sb.XXXXXXXXXX")"
echo "${FULL_PROFILE}" > "${PROFILE_FILE}"

# Trap to clean up the temp file on exit
# shellcheck disable=SC2064
trap "rm -f '${PROFILE_FILE}'" EXIT

sandbox-exec -f "${PROFILE_FILE}" -D "TARGET_DIR=${TARGET_DIR}" -D "TMP_DIR=/tmp" -D "HOME_DIR=${HOME}" -D "CACHE_DIR=${HOME}/.cache" "${POSITIONAL_ARGS[@]}"
